# Python
__pycache__/
*.pyc
.venv/
# Scratch
tmp/
# Local machine config (copy config.example.yaml -> config.yaml and edit)
config.yaml
# Local Claude Code settings (personal permissions + opt-in metrics hooks; see handbook/metrics.md)
.claude/settings.local.json
# Local metrics collection output (opt-in metrics hooks; see handbook/metrics.md)
logs/
# Cross-session scratch memory (ephemeral; see AGENTS.md Memory Map)
.cursor/MEMORY.md
# Private overlay (personal data mounts here; never committed to the public repo).
private/
# Agent scratch memory (personal cross-session notes; see AGENTS.md "Memory Map")
.agents/MEMORY.md
# coding-interview skill symlink into the mounted overlay (private/skills/…). The
# anchored trailing-slash rule at the bottom matches an in-place directory; this
# unslashed rule matches the overlay symlink (git treats a symlink as a file).
skills/coding-interview
# Personal job-search profiles synced from the overlay; only the generic template
# and example profiles are tracked (negations keep them addable).
skills/job-search/profiles/*.yaml
!skills/job-search/profiles/_TEMPLATE.yaml
!skills/job-search/profiles/example.yaml
# Per-skill private references (candidate-specific skill content; never shipped).
# The unslashed rule covers overlay symlinks; the trailing-slash rule covers directories.
skills/*/references_private
skills/*/references_private/
# Optional git-ignored personal token list consumed by the leak guard
private/leak_tokens.txt
# Private products (present only if you work in-place with your own data).
# Anchored to the repo root so they never match the tracked examples/ dataset
# (e.g. examples/applications/**, examples/templates/reference.example.docx).
# NOTE: the former /templates/ in-place rule was retired 2026-07-22 — root
# templates/ is now the TRACKED process-file schema folder; in-place resume
# reference DOCX belongs under private/ (see handbook/private-overlay.md).
/applications/
/interviews/
/.agents/inputs/
/skills/coding-interview/
# Generated dated discovery reports under the EXAMPLE config (test/canary runs
# write real dated files here because config.example.yaml points discoveries_dir
# at this tracked dir). Only .gitkeep is meant to be tracked.
examples/applications/1_discoveries/*.md
