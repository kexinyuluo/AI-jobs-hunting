#!/bin/sh
# Pre-push leak guard for the jobs-finder toolkit.
#
# Repo model (post-split): this is the PUBLIC toolkit repo. Personal data lives
# in a separate private overlay repo mounted (git-ignored) at ./private/, so the
# TRACKED tree here must always be publishable. This hook enforces that at push
# time:
#
#   1. Remote-visibility gate. Look at the push destination:
#        * GitHub remote + gh confirms PUBLIC   -> run the content leak guard
#          (scripts/publish/check_public.py). In a maintainer checkout the guard
#          is armed with real identity tokens (config.yaml / private/
#          leak_tokens.txt); in a contributor clone it still runs its
#          token-independent structural checks. Guard fails -> REFUSE the push.
#        * GitHub remote + gh confirms PRIVATE  -> allow without the guard (a
#          private destination can hold anything; this also covers the private
#          overlay repo).
#        * GitHub remote + gh missing/errors    -> cannot verify; treat like an
#          unknown remote and run the guard as a safety net.
#        * Non-GitHub remote                    -> same: run the guard.
#
#   2. The guard is the gate, not the visibility itself: a clean tracked tree is
#      safe to push anywhere; a dirty one is refused everywhere we cannot prove
#      the destination private.
#
# Manual override (reported loudly):  JOBHUNT_ALLOW_PUSH=1 git push ...
#
# Install once (tracked, no git-config change):
#   .venv/bin/python scripts/bootstrap_overlay.py     # or:
#   ln -sf ../../hooks/pre-push .git/hooks/pre-push
#
# Bypass in an emergency with:  git push --no-verify
set -e

remote_name="$1"
remote_url="$2"

if [ "${JOBHUNT_ALLOW_PUSH:-}" = "1" ]; then
    echo "pre-push: JOBHUNT_ALLOW_PUSH=1 set — SKIPPING all leak checks (manual override)." >&2
    echo "pre-push: you are pushing WITHOUT the leak guard. Be certain this is intended." >&2
    exit 0
fi

# ── 1. Remote-visibility gate ────────────────────────────────────────────────
# Parse "<owner>/<repo>" out of common GitHub remote URL shapes:
#   git@github.com:owner/repo(.git)
#   https://github.com/owner/repo(.git)
#   ssh://git@github.com/owner/repo(.git)
owner_repo=""
case "$remote_url" in
    *github.com[:/]*)
        owner_repo=$(printf '%s\n' "$remote_url" \
            | sed -E 's#^.*github\.com[:/]+##; s#\.git$##; s#/$##')
        ;;
esac

# run_guard: yes | no
run_guard="yes"

if [ -n "$owner_repo" ]; then
    if command -v gh >/dev/null 2>&1; then
        is_private=$(gh repo view "$owner_repo" --json isPrivate --jq '.isPrivate' 2>/dev/null || echo "")
        case "$is_private" in
            true)
                echo "pre-push: remote '$owner_repo' is PRIVATE (verified via gh) — allowing without the guard."
                run_guard="no"
                ;;
            false)
                echo "pre-push: remote '$owner_repo' is PUBLIC — running the content leak guard."
                ;;
            *)
                echo "pre-push: WARNING — could not verify visibility of '$owner_repo' via gh" >&2
                echo "pre-push: (no auth / network?). Running the content leak guard as a safety net." >&2
                ;;
        esac
    else
        echo "pre-push: WARNING — 'gh' not found; cannot verify visibility of '$owner_repo'." >&2
        echo "pre-push: Running the content leak guard as a safety net (install gh to skip on private remotes)." >&2
    fi
else
    echo "pre-push: WARNING — non-GitHub remote '$remote_name' ($remote_url); cannot verify" >&2
    echo "pre-push: its visibility. Running the content leak guard as a safety net." >&2
fi

# ── 2. Content leak guard ────────────────────────────────────────────────────
if [ "$run_guard" = "no" ]; then
    echo "pre-push: OK"
    exit 0
fi

PY=".venv/bin/python"
if [ ! -x "$PY" ]; then
    PY="$(command -v python3 || command -v python)"
fi
if [ -z "$PY" ]; then
    echo "pre-push: no python interpreter found to run the leak guard" >&2
    exit 1
fi
if [ -f "config.yaml" ] || [ -f "private/leak_tokens.txt" ]; then
    echo "pre-push: leak guard is ARMED with real identity tokens."
else
    echo "pre-push: leak guard is NOT armed (no config.yaml / leak_tokens.txt);"
    echo "pre-push: running its token-independent structural checks only."
fi
if ! "$PY" scripts/publish/check_public.py; then
    echo "pre-push: REFUSING push — leak guard found violations in the tracked tree." >&2
    echo "pre-push: fix them, or override knowingly with JOBHUNT_ALLOW_PUSH=1." >&2
    exit 1
fi
echo "pre-push: leak guard PASSED."
echo "pre-push: OK"
