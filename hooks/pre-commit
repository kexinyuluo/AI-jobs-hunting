#!/bin/sh
# Pre-commit guard for the jobs-finder toolkit.
#
# Blocks a commit when:
#   1. a vendored copy has drifted from its canonical source
#      (see scripts/vendoring/sync_vendored.py + .../job-search/scripts/_vendor/), or
#   2. the Outlook assistant exposes any email-sending capability, or
#   3. any toolkit/skill Python file fails to byte-compile.
#
# Install once (tracked, no git-config change):
#   ln -sf ../../hooks/pre-commit .git/hooks/pre-commit
#
# Bypass in an emergency with:  git commit --no-verify
set -e

# Prefer the repo venv; fall back to system python3.
PY=".venv/bin/python"
if [ ! -x "$PY" ]; then
    PY="$(command -v python3 || command -v python)"
fi
if [ -z "$PY" ]; then
    echo "pre-commit: no python interpreter found" >&2
    exit 1
fi

echo "pre-commit: checking vendored copies are in sync..."
"$PY" scripts/vendoring/sync_vendored.py --check

echo "pre-commit: enforcing Outlook draft-only policy..."
"$PY" .agents/skills/outlook-email-assistant/scripts/check_draft_only.py

echo "pre-commit: byte-compiling scripts + self-contained skills..."
"$PY" -m compileall -q scripts \
    .agents/skills/job-search/scripts \
    .agents/skills/resume-writer/scripts \
    .agents/skills/application-tracker/scripts \
    .agents/skills/outlook-email-assistant/scripts

# Instruction-file token-budget check — a hard gate: every instruction file
# is within budget today, and any commit that pushes one over must slim it.
echo "pre-commit: instruction-file budget (strict)..."
"$PY" scripts/metrics/instruction_budget.py --strict

echo "pre-commit: OK"
