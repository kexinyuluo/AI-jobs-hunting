{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "store/manifest.envelope.v1",
  "title": "Raw manifest envelope, version 1",
  "description": "Our envelope around one upstream fetch. Additive-only and forever; a true break needs envelope_schema 2 plus a dual reader.",
  "type": "object",
  "required": ["envelope_schema", "fetch_id", "source", "operation", "request", "status", "response_headers", "fetched_at", "tool_version", "payload", "context"],
  "properties": {
    "envelope_schema": {"const": 1},
    "fetch_id": {"type": "string", "pattern": "^[0-9]{8}T[0-9]{6}Z-[0-9]{6}-[0-9a-f]{6}$"},
    "source": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "operation": {"type": "string", "enum": ["board", "search", "jd", "scrape"]},
    "request": {"type": "object"},
    "status": {"type": "integer"},
    "response_headers": {"type": "object"},
    "item_count": {"type": "integer"},
    "fetched_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "duration_ms": {"type": "integer", "minimum": 0},
    "tool_version": {"type": "string"},
    "query": {"type": "object"},
    "pagination": {"type": "object"},
    "error": {"type": "string"},
    "group_id": {"type": "string"},
    "group": {
      "type": "object",
      "required": ["group_id", "member"],
      "properties": {
        "group_id": {"type": "string"},
        "expected": {"type": ["integer", "null"]},
        "member": {"type": "integer", "minimum": 1},
        "attested_complete": {"type": ["boolean", "null"]}
      }
    },
    "payload": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "required": ["blob", "bytes_raw", "content_type"],
          "properties": {
            "blob": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "bytes_raw": {"type": "integer", "minimum": 0},
            "content_type": {"type": "string"}
          }
        }
      ]
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "company": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "profile": {"type": "string", "pattern": "^(profile|acct)-[0-9]{2}$"},
        "account": {"type": "string", "pattern": "^(profile|acct)-[0-9]{2}$"},
        "mailbox": {"type": "string", "pattern": "^(profile|acct)-[0-9]{2}$"}
      }
    }
  }
}
