{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "store/index-header.v1",
  "title": "Index file header line",
  "description": "The first line of every index JSONL file. The note is a deliberate tripwire for an agent that dumps the file against guidance.",
  "type": "object",
  "required": ["_schema", "built_at", "note"],
  "properties": {
    "_schema": {"type": "integer", "minimum": 1},
    "built_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "note": {"type": "string"}
  },
  "additionalProperties": true
}
