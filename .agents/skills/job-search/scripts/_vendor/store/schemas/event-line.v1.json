{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "store/event-line.v1",
  "title": "Observed-event line, version 1",
  "description": "One observation in a posting's events.jsonl (its biography) and, bucketed by capture day, in index/by-day. Event identity is (entity, fetch, type) — re-appending the same identity is a no-op. Observations only: first_seen / seen / changed. NO closure inference.",
  "type": "object",
  "required": ["entity", "fetch", "type"],
  "properties": {
    "entity": {"type": "string"},
    "fetch": {"type": "string"},
    "type": {"type": "string", "enum": ["first_seen", "seen", "changed"]},
    "at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "seq": {"type": "integer", "minimum": 1},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field"],
        "properties": {
          "field": {"type": "string"},
          "old": {},
          "new": {}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
