{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "store/posting-index-line.v1",
  "title": "Posting index summary line, version 1",
  "description": "One compact line per posting in index/postings.jsonl — the ~15 fields code-side filters use. seq is the materialization sequence cursors ride.",
  "type": "object",
  "required": ["key", "company", "title", "seq"],
  "properties": {
    "key": {"type": "string"},
    "identity": {"type": "string", "enum": ["strong", "weak"]},
    "company": {"type": "string"},
    "title": {"type": "string"},
    "location": {"type": "string"},
    "profiles": {"type": "array", "items": {"type": "string"}},
    "first_seen": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "last_seen": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "posted_at": {"type": ["string", "null"], "description": "source-claimed posting date (may be null)"},
    "visa": {"type": "string"},
    "workplace": {"type": "string"},
    "level": {"type": "string"},
    "source": {"type": "string"},
    "seq": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": true
}
