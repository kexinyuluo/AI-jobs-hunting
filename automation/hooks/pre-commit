#!/bin/sh
# Pre-commit guard for the jobs-finder toolkit.
#
# Blocks a commit when:
#   1. a vendored copy has drifted from its canonical source
#      (see automation/vendoring/sync_vendored.py + .../job-search/scripts/_vendor/), or
#   2. the Outlook assistant exposes any email-sending capability, or
#   3. any toolkit/skill Python file fails to byte-compile.
#
# Install once (tracked, no git-config change):
#   ln -sf ../../automation/hooks/pre-commit .git/hooks/pre-commit
#
# Bypass in an emergency with:  git commit --no-verify
set -e

# Resolve a Python interpreter, worktree-aware:
#   1. the repo venv at CWD (primary checkout — behavior unchanged);
#   2. the primary checkout's venv via the git common dir (a worktree has no local .venv);
#   3. a system python3/python, but only if it meets the 3.11 floor (CI uses 3.12).
PY=".venv/bin/python"
if [ ! -x "$PY" ]; then
    PY=""
    # In a worktree, .git is a file and the real repo (with its .venv) is the common dir.
    # --git-common-dir output may be absolute or relative to CWD; both resolve here.
    common_dir="$(git rev-parse --git-common-dir 2>/dev/null || true)"
    if [ -n "$common_dir" ] && [ -x "$common_dir/../.venv/bin/python" ]; then
        PY="$common_dir/../.venv/bin/python"
    fi
fi
if [ -z "$PY" ]; then
    # No venv anywhere: accept a system interpreter only if it is >= 3.11.
    for cand in python3 python; do
        p="$(command -v "$cand" 2>/dev/null)" || continue
        if "$p" -c 'import sys; sys.exit(0 if sys.version_info >= (3, 11) else 1)' 2>/dev/null; then
            PY="$p"
            break
        fi
    done
fi
if [ -z "$PY" ]; then
    sys_py="$(command -v python3 || command -v python || true)"
    if [ -n "$sys_py" ]; then
        ver="$("$sys_py" -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null || echo '?')"
        echo "pre-commit: repo requires Python 3.11+; found $ver at $sys_py." >&2
    else
        echo "pre-commit: repo requires Python 3.11+; no python interpreter found." >&2
    fi
    echo "pre-commit: create a .venv (python3.11 -m venv .venv) or point the hook at a 3.11+ interpreter." >&2
    exit 1
fi

echo "pre-commit: checking vendored copies are in sync..."
"$PY" automation/vendoring/sync_vendored.py --check

echo "pre-commit: enforcing Outlook draft-only policy..."
"$PY" skills/outlook-email-assistant/scripts/check_draft_only.py

echo "pre-commit: byte-compiling automation + self-contained skills..."
"$PY" -m compileall -q automation \
    skills/job-search/scripts \
    skills/resume-writer/scripts \
    skills/application-tracker/scripts \
    skills/outlook-email-assistant/scripts

# Instruction-file token-budget check — a hard gate: every instruction file
# is within budget today, and any commit that pushes one over must slim it.
echo "pre-commit: instruction-file budget (strict)..."
"$PY" automation/metrics/instruction_budget.py --strict

echo "pre-commit: reconciler (process-layer schemas)..."
"$PY" automation/reconcile/reconcile.py --check

echo "pre-commit: OK"
